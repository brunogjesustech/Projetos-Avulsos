#include <Wire.h>             // Comunicação I2C (usada pelo OLED)
#include <Adafruit_GFX.h>     // Biblioteca gráfica base da Adafruit
#include <Adafruit_SSD1306.h> // Driver do display OLED SSD1306

// --- Dimensões do display ---
#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT 64
#define BUZZER_PIN    8   // Pino digital onde o buzzer passivo está conectado

// --- Inicializa o display via I2C, sem pino de reset (-1) ---
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, -1);

// --- Pino analógico do potenciômetro (define a estação) ---
const int potPin = A0;

// --- Controle de qual estação está ativa e quando foi trocada ---
int estacaoAtual = -1;         // Estação em exibição (-1 = nenhuma inicializada)
unsigned long tempoTroca = 0;
bool melodiaTocada = false;  // Melodia da estação atual já tocou?  // Timestamp (ms) da última troca de estação

// --- Variáveis para alternância de imagens na mensagem final ---
bool mostrarSegundaImagem = false;
unsigned long ultimaTroca = 0;

