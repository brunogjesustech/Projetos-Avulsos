// =====================================================
// BEEP — Gera tom no buzzer passivo via digitalWrite
// Não usa tone()/Timer2, sem conflito com o display I2C
// pino      : pino digital do buzzer
// frequencia: Hz da nota
// duracao   : duração em milissegundos
// =====================================================
void beep(int pino, int frequencia, int duracao) {
  long periodo = 1000000L / frequencia / 2;
  long ciclos  = (long)frequencia * duracao / 1000;

  for (long i = 0; i < ciclos; i++) {
    digitalWrite(pino, HIGH);
    delayMicroseconds(periodo);
    digitalWrite(pino, LOW);
    delayMicroseconds(periodo);
  }
}

