// =====================================================
// SETUP — Executado uma única vez ao ligar o Arduino
// =====================================================

void setup() {
  pinMode(8, OUTPUT);
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  tocarJingleIntro();
  introRadio();
  
}

// =====================================================
// LOOP — Executado continuamente após o setup
// Lê o potenciômetro, determina a estação e
// exibe fase de texto (5s) ou animação conforme o tempo
// =====================================================

void loop() {
  // --- Leitura do potenciômetro (0-1023) ---
  int valor = analogRead(potPin);
  int estacao;

  // --- Mapeamento do valor analógico para 6 estações ---
  if      (valor < 170) estacao = 0; // 88.1 FM — Estrelas
  else if (valor < 340) estacao = 1; // 92.5 FM — Coração
  else if (valor < 510) estacao = 2; // 96.7 FM — Carro
  else if (valor < 680) estacao = 3; // 101.3 FM — Chuva
  else if (valor < 850) estacao = 4; // 104.6 FM — Casinha
  else                  estacao = 5; // 107.9 FM — Mensagem Especial

  // --- Detecta troca de estação e reseta o timer ---
  if (estacao != estacaoAtual) {
    estacaoAtual = estacao;
    tempoTroca = millis();
    melodiaTocada = false;
  }

  display.clearDisplay();

  // Tempo decorrido desde a entrada na estação atual
  unsigned long tempoNaEstacao = millis() - tempoTroca;

  // ---- FASE 1: Texto (primeiros 5 segundos) ----
  if (tempoNaEstacao < 5000UL) {
    display.setTextSize(1);

    switch (estacaoAtual) {
      case 0: // 88.1 FM — Estrelas
        textoCentralizado("88.1 FM", 0);
        textoCentralizado("As primeiras", 20);
        textoCentralizado("estrelas aparecem", 33);
        textoCentralizado("antes da noite.", 46);
        break;

      case 1: // 92.5 FM — Coração
        textoCentralizado("92.5 FM", 0);
        textoCentralizado("Algumas pessoas", 20);
        textoCentralizado("acalmam o mundo", 33);
        textoCentralizado("sem perceber.", 46);
        break;

      case 2: // 96.7 FM — Carro
        textoCentralizado("96.7 FM", 0);
        textoCentralizado("Toda jornada", 20);
        textoCentralizado("merece um momento", 33);
        textoCentralizado("pra respirar.", 46);
        break;

      case 3: // 101.3 FM — Chuva
        textoCentralizado("101.3 FM", 0);
        textoCentralizado("Depois da chuva,", 20);
        textoCentralizado("ate o silencio", 33);
        textoCentralizado("parece bonito.", 46);
        break;

      case 4: // 104.6 FM — Casinha
        textoCentralizado("104.6 FM", 0);
        textoCentralizado("Alguns lugares", 18);
        textoCentralizado("parecem casa.", 30);
        textoCentralizado("Algumas pessoas", 42);
        textoCentralizado("tambem.", 54);
        break;

      case 5: // 107.9 FM — Mensagem Especial
        textoCentralizado("107.9 FM", 0);
        textoCentralizado("Mensagem Especial", 30);
        break;
    }

    // --- Barra de progresso na base da tela ---
    display.drawRect(0, 61, 128, 3, WHITE);                         // Contorno
    int prog = (int)(tempoNaEstacao * 126UL / 5000UL);              // Progresso 0-126px
    display.fillRect(1, 62, prog, 1, WHITE);                        // Preenchimento

    // Toca a melodia uma vez ao entrar na estação, após exibir o texto
    if (!melodiaTocada && tempoNaEstacao > 300) {
      melodiaTocada = true;
      display.display(); // Garante que o texto aparece antes de bloquear
      switch (estacaoAtual) {
        case 0: somEstrelas(); break;
        case 1: somCoracao();  break;
        case 2: somCarro();    break;
        case 3: somChuva();    break;
        case 4: somCasinha();  break;
        case 5: somEspecial(); break;
      }
    }

  // ---- FASE 2: Animação (após 5 segundos) ----
  } else {
    unsigned long tempoAnim = tempoNaEstacao - 5000UL; // Tempo dentro da animação

    switch (estacaoAtual) {
      case 0: animacaoEstrelas();        break;
      case 1: animacaoCoracao();         break;
      case 2: animacaoCarro();           break;
      case 3: animacaoChuva();           break;
      case 4: animacaoCasinha();         break;
      case 5: mensagemFinal(tempoAnim);  break;
    }
  }

  // Envia o buffer para o display e aguarda ~35ms (~28fps)
  display.display();
  delay(35);
}
